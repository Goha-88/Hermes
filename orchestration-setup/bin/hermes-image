#!/usr/bin/env python3
"""hermes-image — генерация картинки через OpenRouter gemini-2.5-flash-image (без FAL).

Usage:  hermes-image "<prompt>" [output.png]
Печатает путь к сохранённому PNG в stdout; стоимость — в stderr.
Ключ берётся из окружения или ~/.hermes/.env (OPENROUTER_API_KEY).
"""
import os, sys, json, base64, urllib.request, time, pathlib, re


def load_key():
    k = os.environ.get("OPENROUTER_API_KEY")
    if k:
        return k
    env = pathlib.Path.home() / ".hermes" / ".env"
    if env.exists():
        for line in env.read_text().splitlines():
            if line.startswith("OPENROUTER_API_KEY="):
                return line.split("=", 1)[1].strip()
    sys.exit("OPENROUTER_API_KEY not found")


def main():
    if len(sys.argv) < 2:
        sys.exit('Usage: hermes-image "<prompt>" [output.png]')
    prompt = sys.argv[1]
    out = sys.argv[2] if len(sys.argv) > 2 else None
    key = load_key()

    req = urllib.request.Request(
        "https://openrouter.ai/api/v1/chat/completions",
        data=json.dumps({
            "model": "google/gemini-2.5-flash-image",
            "messages": [{"role": "user", "content": prompt}],
            "modalities": ["image", "text"],
        }).encode(),
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"},
        method="POST",
    )
    d = json.load(urllib.request.urlopen(req, timeout=180))
    msg = d["choices"][0]["message"]
    imgs = msg.get("images") or []
    if not imgs:
        sys.exit("no image returned: " + (msg.get("content") or "")[:200])

    iu = imgs[0].get("image_url")
    url = iu["url"] if isinstance(iu, dict) else iu
    raw = base64.b64decode(url.split(",", 1)[1])

    if not out:
        cache = pathlib.Path.home() / ".hermes" / "image_cache"
        cache.mkdir(exist_ok=True)
        slug = (re.sub(r"[^a-z0-9]+", "-", prompt.lower())[:30].strip("-")) or "image"
        out = str(cache / f"{slug}-{int(time.time())}.png")

    pathlib.Path(out).write_bytes(raw)
    u = d.get("usage", {})
    cost = u.get("completion_tokens", 0) * 0.0000025 + u.get("prompt_tokens", 0) * 0.0000003
    print(out)
    print(f"[ok] {len(raw)} bytes · ~${cost:.4f}", file=sys.stderr)


if __name__ == "__main__":
    main()
