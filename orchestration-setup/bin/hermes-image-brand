#!/usr/bin/env python3
"""hermes-image-brand — лого/брендинг/текст через Replicate Recraft V3.

Usage:  hermes-image-brand "<prompt>" [style] [output]
        style: any (по умолч.), digital_illustration, vector_illustration,
               realistic_image, icon, logo_raster ... (см. Recraft styles)
Лучшая модель для логотипов, текста на картинке, вектора. ~$0.04/картинка.
vector_illustration возвращает SVG. Токен — из окружения / ~/.hermes/.env.
"""
import os, sys, json, time, urllib.request, pathlib, re

MODEL = "recraft-ai/recraft-v3"


def token():
    t = os.environ.get("REPLICATE_API_TOKEN")
    if t:
        return t
    env = pathlib.Path.home() / ".hermes" / ".env"
    if env.exists():
        for line in env.read_text().splitlines():
            if line.startswith("REPLICATE_API_TOKEN="):
                return line.split("=", 1)[1].strip()
    sys.exit("REPLICATE_API_TOKEN not found")


def api(url, tok, data=None):
    h = {"Authorization": f"Bearer {tok}", "Content-Type": "application/json"}
    req = urllib.request.Request(url, data=json.dumps(data).encode() if data else None,
                                 headers=h, method="POST" if data else "GET")
    with urllib.request.urlopen(req, timeout=120) as r:
        return json.load(r)


def main():
    if len(sys.argv) < 2:
        sys.exit('Usage: hermes-image-brand "<prompt>" [style] [output]')
    prompt = sys.argv[1]
    style = sys.argv[2] if len(sys.argv) > 2 else "any"
    out = sys.argv[3] if len(sys.argv) > 3 else None
    tok = token()

    pred = api(f"https://api.replicate.com/v1/models/{MODEL}/predictions", tok,
               {"input": {"prompt": prompt, "style": style, "size": "1024x1024"}})
    for _ in range(60):
        if pred.get("status") in ("succeeded", "failed", "canceled"):
            break
        time.sleep(2)
        pred = api(pred["urls"]["get"], tok)
    if pred.get("status") != "succeeded":
        sys.exit("generation failed: " + str(pred.get("error") or pred.get("status")))

    output = pred["output"]
    url = output[0] if isinstance(output, list) else output
    raw = urllib.request.urlopen(url, timeout=120).read()

    ext = "svg" if url.lower().split("?")[0].endswith(".svg") else "png"
    if not out:
        cache = pathlib.Path.home() / ".hermes" / "image_cache"
        cache.mkdir(exist_ok=True)
        slug = (re.sub(r"[^a-z0-9]+", "-", prompt.lower())[:30].strip("-")) or "brand"
        out = str(cache / f"recraft-{slug}-{int(time.time())}.{ext}")
    pathlib.Path(out).write_bytes(raw)
    print(out)
    print(f"[ok] {len(raw)} bytes · Recraft V3 ({style}) · ~$0.04", file=sys.stderr)


if __name__ == "__main__":
    main()
